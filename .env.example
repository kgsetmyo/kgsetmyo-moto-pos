# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret (Supabase → Project Settings → API → JWT Secret)
# Enables local HS256 signature verification for proxy/API session checks.
SUPABASE_JWT_SECRET=your-jwt-secret

# Supavisor — transaction mode (port 6543) for scripts, seeds, short mutations
# URL-encode special chars in password (@ → %40). User format: postgres.PROJECT_REF
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&connection_limit=5

# Supavisor — session mode (port 5432) for migrations, Z-report SQL, teardown scripts
DIRECT_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# See .env.production.example for production variable layout and pooler usage table.

# Admin / test accounts (set real values in .env — never commit)
ADMIN_EMAIL=
ADMIN_PASSWORD=
CASHIER_EMAIL=
CASHIER_PASSWORD=
