// Moto POS — Motorcycle Spare Parts Shop
// FIFO inventory + bike compatibility matrix
// Target: Supabase PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  CASHIER
}

enum PaymentMethod {
  CASH
  MOBILE_BANKING
  CREDIT
}

enum SaleStatus {
  COMPLETED
  VOIDED
  REFUNDED
}

enum CreditLedgerType {
  SALE
  PAYMENT
  ADJUSTMENT
}

// ─── Auth & Users (extends Supabase auth.users) ──────────────────────────────

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String   @map("full_name")
  role      UserRole @default(CASHIER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salesRecorded       Sale[]              @relation("SaleCashier")
  inventoryBatches    InventoryBatch[]    @relation("BatchCreator")
  paymentsRecorded    Payment[]           @relation("PaymentRecorder")
  creditEntries       CreditLedgerEntry[] @relation("CreditRecorder")
  expensesRecorded    Expense[]           @relation("ExpenseRecorder")
  dailyCloses         DailyClose[]        @relation("DailyCloseUser")

  @@map("profiles")
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Brand {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  products  Product[]

  @@map("brands")
}

model Category {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  products  Product[]

  @@map("categories")
}

model Product {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku               String   @unique
  barcode           String?  @unique
  name              String
  brandId           String   @map("brand_id") @db.Uuid
  categoryId        String   @map("category_id") @db.Uuid
  lowStockThreshold Int      @default(5) @map("low_stock_threshold")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  brand            Brand                 @relation(fields: [brandId], references: [id])
  category         Category              @relation(fields: [categoryId], references: [id])
  compatibilities  ProductCompatibility[]
  inventoryBatches InventoryBatch[]
  saleLineItems    SaleLineItem[]

  @@index([name])
  @@index([brandId])
  @@index([categoryId])
  @@map("products")
}

// ─── Bike Compatibility Matrix ───────────────────────────────────────────────

model BikeBrand {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String      @unique
  createdAt DateTime    @default(now()) @map("created_at")
  models    BikeModel[]

  @@map("bike_brands")
}

model BikeModel {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bikeBrandId String                 @map("bike_brand_id") @db.Uuid
  name        String
  createdAt   DateTime               @default(now()) @map("created_at")
  bikeBrand   BikeBrand              @relation(fields: [bikeBrandId], references: [id])
  compatibilities ProductCompatibility[]

  @@unique([bikeBrandId, name])
  @@index([bikeBrandId])
  @@map("bike_models")
}

/// A product can map to many bike model + year combinations.
model ProductCompatibility {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  bikeModelId String    @map("bike_model_id") @db.Uuid
  year        Int
  createdAt   DateTime  @default(now()) @map("created_at")

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  bikeModel BikeModel @relation(fields: [bikeModelId], references: [id], onDelete: Cascade)

  @@unique([productId, bikeModelId, year])
  @@index([bikeModelId, year])
  @@index([productId])
  @@map("product_compatibilities")
}

// ─── FIFO Inventory ──────────────────────────────────────────────────────────

model InventoryBatch {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId          String   @map("product_id") @db.Uuid
  batchNumber        String?  @map("batch_number")
  costPrice          Decimal  @map("cost_price") @db.Decimal(12, 2)
  sellingPrice       Decimal  @map("selling_price") @db.Decimal(12, 2)
  quantityReceived   Int      @map("quantity_received")
  quantityRemaining  Int      @map("quantity_remaining")
  receivedAt         DateTime @default(now()) @map("received_at")
  notes              String?
  createdById        String?  @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")

  product      Product                @relation(fields: [productId], references: [id])
  createdBy    Profile?               @relation("BatchCreator", fields: [createdById], references: [id])
  allocations  SaleBatchAllocation[]

  @@index([productId, receivedAt])
  @@index([productId, quantityRemaining])
  @@map("inventory_batches")
}

// ─── Customers & Credit (အကြွေးစနစ်) ─────────────────────────────────────────

model Customer {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  phone         String?
  email         String?
  address       String?
  creditBalance Decimal  @default(0) @map("credit_balance") @db.Decimal(12, 2)
  creditLimit   Decimal? @map("credit_limit") @db.Decimal(12, 2)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sales         Sale[]
  payments      Payment[]
  creditLedger  CreditLedgerEntry[]

  @@index([name])
  @@index([phone])
  @@map("customers")
}

model CreditLedgerEntry {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId   String           @map("customer_id") @db.Uuid
  type         CreditLedgerType
  amount       Decimal          @db.Decimal(12, 2) // + increases debt, - decreases
  balanceAfter Decimal          @map("balance_after") @db.Decimal(12, 2)
  saleId       String?          @map("sale_id") @db.Uuid
  paymentId    String?          @map("payment_id") @db.Uuid
  notes        String?
  recordedById String?          @map("recorded_by") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at")

  customer   Customer @relation(fields: [customerId], references: [id])
  sale       Sale?    @relation(fields: [saleId], references: [id])
  payment    Payment? @relation(fields: [paymentId], references: [id])
  recordedBy Profile? @relation("CreditRecorder", fields: [recordedById], references: [id])

  @@index([customerId, createdAt])
  @@map("credit_ledger_entries")
}

// ─── Sales & POS ───────────────────────────────────────────────────────────────

model Sale {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber String     @unique @map("invoice_number")
  customerId    String?    @map("customer_id") @db.Uuid
  cashierId     String     @map("cashier_id") @db.Uuid
  subtotal      Decimal    @db.Decimal(12, 2)
  discount      Decimal    @default(0) @db.Decimal(12, 2)
  total         Decimal    @db.Decimal(12, 2)
  totalCogs     Decimal    @default(0) @map("total_cogs") @db.Decimal(12, 2)
  grossProfit   Decimal    @default(0) @map("gross_profit") @db.Decimal(12, 2)
  status        SaleStatus @default(COMPLETED)
  notes         String?
  dailyCloseId  String?    @map("daily_close_id") @db.Uuid
  createdAt     DateTime   @default(now()) @map("created_at")

  customer      Customer?           @relation(fields: [customerId], references: [id])
  cashier       Profile             @relation("SaleCashier", fields: [cashierId], references: [id])
  dailyClose    DailyClose?         @relation(fields: [dailyCloseId], references: [id])
  lineItems     SaleLineItem[]
  payments      Payment[]
  creditEntries CreditLedgerEntry[]

  @@index([createdAt])
  @@index([cashierId])
  @@index([customerId])
  @@map("sales")
}

model SaleLineItem {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId     String  @map("sale_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  lineTotal  Decimal @map("line_total") @db.Decimal(12, 2)
  totalCogs  Decimal @default(0) @map("total_cogs") @db.Decimal(12, 2)

  sale        Sale                  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product               @relation(fields: [productId], references: [id])
  allocations SaleBatchAllocation[]

  @@index([saleId])
  @@index([productId])
  @@map("sale_line_items")
}

/// FIFO allocation: which batches were consumed for each line item.
model SaleBatchAllocation {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleLineItemId String  @map("sale_line_item_id") @db.Uuid
  batchId        String  @map("batch_id") @db.Uuid
  quantity       Int
  unitCost       Decimal @map("unit_cost") @db.Decimal(12, 2)
  subtotalCogs   Decimal @map("subtotal_cogs") @db.Decimal(12, 2)

  saleLineItem SaleLineItem   @relation(fields: [saleLineItemId], references: [id], onDelete: Cascade)
  batch        InventoryBatch @relation(fields: [batchId], references: [id])

  @@index([saleLineItemId])
  @@index([batchId])
  @@map("sale_batch_allocations")
}

model Payment {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId        String?       @map("sale_id") @db.Uuid
  customerId    String?       @map("customer_id") @db.Uuid
  method        PaymentMethod
  amount        Decimal       @db.Decimal(12, 2)
  slipUrl       String?       @map("slip_url")
  reference     String?
  recordedById  String?       @map("recorded_by") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")

  sale          Sale?               @relation(fields: [saleId], references: [id])
  customer      Customer?           @relation(fields: [customerId], references: [id])
  recordedBy    Profile?            @relation("PaymentRecorder", fields: [recordedById], references: [id])
  creditEntries CreditLedgerEntry[]

  @@index([saleId])
  @@index([customerId])
  @@index([createdAt])
  @@map("payments")
}

// ─── Reporting & Daily Close ───────────────────────────────────────────────────

model DailyClose {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessDate DateTime @unique @map("business_date") @db.Date
  closedById   String   @map("closed_by") @db.Uuid
  totalSales   Decimal  @map("total_sales") @db.Decimal(12, 2)
  cashTotal    Decimal  @map("cash_total") @db.Decimal(12, 2)
  mobileTotal  Decimal  @map("mobile_total") @db.Decimal(12, 2)
  creditTotal  Decimal  @map("credit_total") @db.Decimal(12, 2)
  totalCogs    Decimal  @map("total_cogs") @db.Decimal(12, 2)
  grossProfit  Decimal  @map("gross_profit") @db.Decimal(12, 2)
  expenseTotal Decimal  @default(0) @map("expense_total") @db.Decimal(12, 2)
  netProfit    Decimal  @map("net_profit") @db.Decimal(12, 2)
  notes        String?
  closedAt     DateTime @default(now()) @map("closed_at")

  closedBy Profile @relation("DailyCloseUser", fields: [closedById], references: [id])
  sales    Sale[]

  @@map("daily_closes")
}

model Expense {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category     String
  description  String?
  amount       Decimal  @db.Decimal(12, 2)
  expenseDate  DateTime @map("expense_date") @db.Date
  recordedById String?  @map("recorded_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  recordedBy Profile? @relation("ExpenseRecorder", fields: [recordedById], references: [id])

  @@index([expenseDate])
  @@map("expenses")
}

model ShopSettings {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessName String   @map("business_name")
  phone        String?
  address      String?
  logoUrl      String?  @map("logo_url")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("shop_settings")
}
